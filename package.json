{
  "name": "kestrel-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo dev --filter=@kestrel/web",
    "dev:admin": "turbo dev --filter=@kestrel/admin",
    "build:web": "turbo build --filter=@kestrel/web",
    "build:admin": "turbo build --filter=@kestrel/admin"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0"
  }
}
